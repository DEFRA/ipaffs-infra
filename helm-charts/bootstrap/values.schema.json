{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "properties": {
    "azure": {
      "type": "object",
      "required": [
        "location"
      ]
    },
    "environment": {
      "type": "string"
    },
    "ipaffsConfig": {
      "type": "object",
      "properties": {
        "data": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "secretStore": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        }
      }
    },
    "externalSecret": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "refreshInterval": {
          "type": "string"
        },
        "secrets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretKey": {
                "type": "string"
              },
              "remoteKey": {
                "type": "string"
              }
            },
            "required": [
              "secretKey",
              "remoteKey"
            ]
          }
        },
        "certs": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "secretKey": {
                "type": "string"
              },
              "remoteKey": {
                "type": "string"
              }
            },
            "required": [
              "secretKey",
              "remoteKey"
            ]
          }
        }
      }
    },
    "project": {
      "type": "string"
    },
    "service": {
      "type": "string"
    },
    "serviceBus": {
      "type": "object",
      "properties": {
        "queues": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "topics": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "subscriptions": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "name"
                ],
                "additionalProperties": false
              }
            ]
          }
        }
      }
    }
  },
  "required": [
    "environment"
  ],
  "title": "Values",
  "type": "object"
}
